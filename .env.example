# OpenAI API key — used by every AI route:
#   /api/bridges · /api/name · /api/seeds · /api/talk · /api/blindspot · /api/tradeoff
# Without it, the app runs in a deterministic "sample mode" (hand-written and
# graph-grounded fallbacks), so the full flow still works end-to-end.
OPENAI_API_KEY=

# Optional: override the model (default: gpt-5.4-mini)
OPENAI_MODEL=gpt-5.4-mini
